# Environment variables for Mycomai
# Last updated: 2026-03-19

# --- OpenAI ---
OPENAI_API_KEY='YOUR_OPENAI_API_KEY'
OPENAI_EMBEDDING_MODEL='text-embedding-3-small'
OPENAI_CHAT_MODEL='gpt-4o'
OPENAI_TEMPERATURE='0.7'
# OPENAI_SUMMARIZE_MODEL='gpt-4o-mini'  # Teams 문의 요약 모델 (기본값: gpt-4o-mini)

# --- Jira ---
JIRA_BASE_URL='https://your-company.atlassian.net'
JIRA_API_TOKEN='YOUR_JIRA_API_TOKEN'
JIRA_EMAIL='your-email@example.com'
# 콤마로 구분하여 여러 프로젝트 입력
JIRA_PROJECT_KEY='PROJECT1,PROJECT2'
JIRA_MAX_RESULTS='50'

# --- Confluence ---
CONFLUENCE_BASE_URL='https://your-company.atlassian.net/wiki'
CONFLUENCE_API_TOKEN='YOUR_CONFLUENCE_API_TOKEN'
CONFLUENCE_EMAIL='your-email@example.com'
# 명시적 스페이스 키 (콤마 구분)
CONFLUENCE_SPACE_KEY='SPACE1,SPACE2'
CONFLUENCE_PAGE_LIMIT='25'
# 레이블로 분류된 스페이스 전체 수집 (콤마 구분, 비워두면 사용 안 함)
# 설정 방법: Confluence 스페이스 설정 → Space Details → Labels에서 레이블 추가
CONFLUENCE_SPACE_LABELS=''

# --- Microsoft 365 (SharePoint / Teams) ---
# Azure AD App Registration with application permissions is required.
TENANT_ID='YOUR_AZURE_AD_TENANT_ID'
CLIENT_ID='YOUR_AZURE_AD_CLIENT_ID'
CLIENT_SECRET='YOUR_AZURE_AD_CLIENT_SECRET'
SHAREPOINT_SITE_NAME='' # 수집할 SharePoint 사이트명 (비워두면 수집 안 함)
TEAMS_GROUP_NAME=''     # 수집할 Teams 그룹명 (비워두면 수집 안 함)
# Teams 일반 채팅 수집 (Chat.Read.All + User.Read.All Application 권한 필요)
# 채팅방 ID만 콤마로 구분하여 입력 (ID 확인: teams_extractor.py 실행)
TEAMS_CHAT_IDS=''
# Teams 문의 채널 설정 (답변 부족 시 수동 문의 버튼)
# Incoming Webhook URL: Teams 채널 → ... → 커넥터 → Incoming Webhook → 구성 → URL 복사
TEAMS_INQUIRY_WEBHOOK_URL=''

# --- ChromaDB ---
CHROMA_DB_PATH='./db/chroma_db'
COLLECTION_NAME='company_llm_rag_collection'

# --- Persona Configuration ---
# AI 이름
AI_NAME=''
# 회사 이름
COMPANY_NAME=''
# 회사 설명
COMPANY_DESCRIPTION=''
# 아래 두 변수를 비워두면 패키지 내 기본 파일(prompts/*.txt)을 사용합니다.
# SYSTEM_PROMPT_FILE='/path/to/system_prompt.txt'
# RAG_INSTRUCTIONS_FILE='/path/to/rag_instructions.txt'

# --- Admin Dashboard (Optional) ---
# /admin 대시보드 접근 비밀번호 (비워두면 /admin 비활성화)
# ADMIN_PASSWORD='your_secret_password'

# --- Chunking / Retrieval ---
CHUNK_SIZE='512'
CHUNK_OVERLAP='64'
RETRIEVAL_TOP_K='7'    # 템플릿 권장값: 7 (코드 fallback 기본값은 3)
TIKTOKEN_ENCODING='cl100k_base'

# --- Incremental sync / Logging ---
# 비워두면 전체 수집
LOOKBACK_DAYS=''
LOG_LEVEL='INFO'       # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# How to use:
# 1. Copy this file to .env
# 2. Fill in real credentials and targets
# 3. Run via Docker Compose or local PYTHONPATH=src python3 ...
